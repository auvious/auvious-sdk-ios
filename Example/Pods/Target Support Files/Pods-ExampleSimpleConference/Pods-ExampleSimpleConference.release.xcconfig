ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
EXCLUDED_ARCHS[sdk=iphonesimulator*] = arm64
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AuviousSDK" "${PODS_CONFIGURATION_BUILD_DIR}/CocoaMQTTWebsocket_IOS13" "${PODS_CONFIGURATION_BUILD_DIR}/MqttCocoaAsyncSocket_IOS13" "${PODS_CONFIGURATION_BUILD_DIR}/Sentry" "${PODS_CONFIGURATION_BUILD_DIR}/Starscream_IOS13" "${PODS_CONFIGURATION_BUILD_DIR}/SwiftyJSON" "${PODS_ROOT}/AuviousGoogleWebRTC/frameworks"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AuviousSDK/AuviousSDK.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CocoaMQTTWebsocket_IOS13/CocoaMQTTWebsocket_IOS13.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/MqttCocoaAsyncSocket_IOS13/MqttCocoaAsyncSocket_IOS13.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Sentry/Sentry.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Starscream_IOS13/Starscream_IOS13.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/SwiftyJSON/SwiftyJSON.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_LDFLAGS = $(inherited) -framework "AuviousSDK" -framework "CFNetwork" -framework "CocoaMQTTWebsocket_IOS13" -framework "Foundation" -framework "MqttCocoaAsyncSocket_IOS13" -framework "Security" -framework "Sentry" -framework "Starscream_IOS13" -framework "SwiftyJSON" -framework "WebRTC"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/AuviousGoogleWebRTC" "-F${PODS_CONFIGURATION_BUILD_DIR}/AuviousSDK" "-F${PODS_CONFIGURATION_BUILD_DIR}/CocoaMQTTWebsocket_IOS13" "-F${PODS_CONFIGURATION_BUILD_DIR}/MqttCocoaAsyncSocket_IOS13" "-F${PODS_CONFIGURATION_BUILD_DIR}/Sentry" "-F${PODS_CONFIGURATION_BUILD_DIR}/Starscream_IOS13" "-F${PODS_CONFIGURATION_BUILD_DIR}/SwiftyJSON"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
